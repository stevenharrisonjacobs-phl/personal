# Choose a globally unique Google Cloud project ID.
GCP_PROJECT_ID=your-tiller-finance-project
GCP_PROJECT_NAME="Tiller Finance"

# Find this with: gcloud billing accounts list
BILLING_ACCOUNT_ID=000000-000000-000000

# The ID between /d/ and /edit in the Google Sheets URL.
TILLER_SHEET_ID=your-google-sheet-id

# BigQuery settings.
BQ_LOCATION=US
RAW_DATASET=tiller_raw
FINANCE_DATASET=finance
GOLD_DATASET=gold
SYNC_SCHEDULE="every 1 hours"

# Tiller's durable raw balance data is normally in Balance History.
TRANSACTIONS_TAB=Transactions
BALANCE_HISTORY_TAB="Balance History"

# Optional parent for organization-managed Google Cloud accounts.
# GCP_ORGANIZATION_ID=1234567890
# GCP_FOLDER_ID=1234567890
